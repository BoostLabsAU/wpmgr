# WPMgr — self-host environment.
#
# Copy this file to .env and fill in the secrets, then bring up the stack:
#
#   ./scripts/init-env.sh      # copies this file -> .env AND injects fresh secrets
#   # ── or do it by hand ──
#   cp .env.example .env
#   docker compose run --rm api wpmgr-cli gen-secrets   # paste the 4 lines into .env
#
# Variables are grouped:
#   [REQUIRED — ALWAYS]      must be set for ANY boot (dev or prod), or the app exits.
#   [REQUIRED — PRODUCTION]  must be set when WPMGR_ENV=production, or the app exits /
#                            silently disables a feature. Safe defaults exist for dev.
#   [OPTIONAL]               has a working default; set only to override behaviour.
#
# Every WPMGR_* var the app reads is prefixed `WPMGR_`. Values shown after `=` are
# dev defaults / illustrative placeholders — ROTATE every secret before exposing
# the service to a network.


# =============================================================================
# [REQUIRED — ALWAYS]  Set these or the app will not boot.
# =============================================================================

# Session signing secret. Format: opaque random string, >=32 characters; must NOT
# be empty and must NOT start with "change-me". The app hard-fails boot otherwise.
# run: docker compose run --rm api wpmgr-cli gen-secrets   (or: openssl rand -base64 48)
WPMGR_SESSION_SECRET=

# Postgres APP role — the UNPRIVILEGED login the app connects as (NOSUPERUSER
# NOBYPASSRLS; RLS is the real tenant-isolation backstop). The app refuses to boot
# if this role can bypass RLS (see WPMGR_ALLOW_RLS_BYPASS_ROLE).
# Format: role name. e.g. wpmgr_app
WPMGR_DB_USER=wpmgr_app
# Password for WPMGR_DB_USER. Format: string. e.g. a-long-random-password
WPMGR_DB_PASSWORD=wpmgr-app-dev-secret


# =============================================================================
# [REQUIRED — PRODUCTION]  Safe dev defaults below; you MUST change these for a
# real, network-exposed deploy (several hard-fail boot when WPMGR_ENV=production).
# =============================================================================

# Mark the deployment as production: enables JSON logs AND the hard-fail guards
# (rejects the committed dev agent key, requires the age secret below, etc.).
# Format: "production" (or "prod"); anything else = development. e.g. production
WPMGR_ENV=development

# Postgres host/port/name/sslmode. In docker-compose the host is the service name
# "postgres". Format: WPMGR_DB_HOST hostname; PORT integer; SSLMODE one of
# disable|require|verify-ca|verify-full. e.g. postgres / 5432 / wpmgr / disable
WPMGR_DB_HOST=localhost
WPMGR_DB_PORT=5432
WPMGR_DB_NAME=wpmgr
WPMGR_DB_SSLMODE=disable
# Owner/superuser DSN used ONLY to run migrations (CREATE ROLE + privileged DDL).
# Empty => reuse the app DSN (single-DSN dev). Set it in prod to a privileged role;
# when set, a boot-time table-privilege probe also runs.
# Format: full postgres URL.
# e.g. postgres://wpmgr:OWNERPASS@postgres:5432/wpmgr?sslmode=disable
WPMGR_DB_MIGRATION_DSN=

# Redis address (session store + autologin consume store).
# Format: host:port. e.g. redis:6379
WPMGR_REDIS_ADDR=localhost:6379

# Secrets-at-rest key (age X25519). Encrypts stored SMTP passwords + per-site
# destination secrets. EMPTY => a fresh EPHEMERAL identity each boot (dev only):
# every restart orphans previously stored secrets. In production an empty value
# HARD-FAILS boot. Format: age secret key, the literal "AGE-SECRET-KEY-1..."
# (UPPERCASE; mixed case is rejected).
# run: docker compose run --rm api wpmgr-cli gen-secrets   (or: age-keygen)
WPMGR_SITE_DEST_AGE_SECRET=

# Control-plane Ed25519 agent-signing keypair. Signs CP->agent commands; the public
# half is handed to agents at enrollment to verify commands. EMPTY => CP->agent
# commands, autologin mint, and ADR-042 self-update are DISABLED (warned, not fatal).
# In production the committed DEV key below is REJECTED — generate a fresh pair.
# Format: PRIVATE = base64-std of the raw 64-byte key (seed||pub);
#         PUBLIC  = base64-std of the raw 32-byte key. The two must correspond.
# run: docker compose run --rm api wpmgr-cli gen-secrets   (or: ./scripts/gen-keys.sh)
# !! The values below are a PUBLIC committed DEV pair — DO NOT use in production. !!
WPMGR_AGENT_SIGNING_PRIVATE_KEY=aWuH1W3DSfBwuE/V/H9BEmV9IAJfK5d6F2RDfYSj/raBW+b26qHT3spd1gHSw7aXEXxZkg9E9WMspibSjSFsnQ==
WPMGR_AGENT_SIGNING_PUBLIC_KEY=gVvm9uqh097KXdYB0sO2lxF8WZIPRPVjLKYm0o0hbJ0=

# Public base URL of THIS control plane, reachable by agents and embedded in
# invite/reset/manifest/presign-callback links. Format: URL, no trailing slash.
# e.g. https://wpmgr.example.com
WPMGR_PUBLIC_BASE_URL=http://localhost:8080

# S3-compatible object storage (self-host: SeaweedFS; managed: AWS S3). The agent
# must be able to reach presigned URLs minted from WPMGR_S3_ENDPOINT — the
# in-network default http://seaweedfs:8333 is NOT reachable by an external agent,
# so for any real WP host set it to a publicly reachable hostname (e.g. a tunnel).
# Format: WPMGR_S3_ENDPOINT URL; BUCKET name; ACCESS_KEY / SECRET_KEY strings.
# EMPTY bucket => backup/restore return 501 and self-update is disabled (warned).
# e.g. http://seaweedfs:8333 / wpmgr-backups / wpmgr / a-long-random-secret
WPMGR_S3_ENDPOINT=http://localhost:8333
WPMGR_S3_BUCKET=wpmgr-backups
WPMGR_S3_ACCESS_KEY=wpmgr
WPMGR_S3_SECRET_KEY=wpmgr-dev-secret
# AWS region string. Format: region. e.g. us-east-1
WPMGR_S3_REGION=us-east-1
# Path-style addressing — required true for SeaweedFS/MinIO. Format: true|false.
WPMGR_S3_FORCE_PATH_STYLE=true


# =============================================================================
# [OPTIONAL]  Working defaults; set only to override.
# =============================================================================

# ---- Server ----
# API listen address. Format: Go host:port. e.g. :8080
WPMGR_HTTP_ADDR=:8080
# Log level. Format: debug|info|warn|error. e.g. info
WPMGR_LOG_LEVEL=info
# Path to an optional YAML config file (precedence defaults<file<env).
# Format: filesystem path; empty skips file loading. e.g. /etc/wpmgr/config.yaml
WPMGR_CONFIG_FILE=

# ---- docker-compose HOST ports (compose-only; the Go app never reads these) ----
# Which HOST port each container is published on. Only the host side changes —
# container-side ports stay fixed, so in-network wiring (WPMGR_S3_ENDPOINT,
# WPMGR_OIDC_ISSUER, etc.) is unaffected. Defaults deliberately avoid the common
# 80 / 8080 so a first boot never collides with something already listening.
#   dashboard -> http://localhost:8088     api -> http://localhost:8081
# Format: integer host port.
WPMGR_WEB_PORT=8088
WPMGR_API_PORT=8081
WPMGR_S3_PORT=8333
WPMGR_DEX_PORT=5556
# Observability profile only (published with --profile observability):
WPMGR_GRAFANA_PORT=3000
WPMGR_OTLP_GRPC_PORT=4317
WPMGR_OTLP_HTTP_PORT=4318

# ---- Auth / sessions ----
# Dev escape hatch: allow boot even if the DB role can bypass RLS. MUST be false in
# production. Format: true|false.
WPMGR_ALLOW_RLS_BYPASS_ROLE=false
# Redis password (empty = no auth). Format: string.
WPMGR_REDIS_PASSWORD=
# Session lifetimes. Format: Go duration. e.g. 168h (idle), 720h (absolute).
WPMGR_AUTH_IDLE_TIMEOUT=168h
WPMGR_AUTH_ABSOLUTE_EXPIRY=720h
# OIDC relying party (self-host via Dex). Empty issuer => email+password only.
# A non-empty issuer that fails discovery HARD-FAILS boot. Format: URLs / strings.
WPMGR_OIDC_ISSUER=
WPMGR_OIDC_CLIENT_ID=
WPMGR_OIDC_CLIENT_SECRET=
WPMGR_OIDC_REDIRECT_URL=http://localhost:8080/auth/oidc/callback

# ---- Agent protocol tuning ----
# Anti-replay signature skew, heartbeat-staleness threshold, health-job cadence.
# Format: Go duration. e.g. 5m / 10m / 5m
WPMGR_AGENT_SIGNATURE_SKEW=5m
WPMGR_AGENT_STALE_AFTER=10m
WPMGR_AGENT_HEALTH_INTERVAL=5m

# ---- Backups (M4) ----
# Presign TTL; retention window; monthly-archive keep; scheduler + GC cadence;
# per-attempt CP->agent backup/restore timeout (must outlast a real-site snapshot).
# Format: durations / integers. e.g. 1h / 30 / 12 / 5m / 1h / 10m
WPMGR_BACKUP_PRESIGN_TTL=1h
WPMGR_BACKUP_RETENTION_DAYS=30
WPMGR_BACKUP_MONTHLY_ARCHIVE_KEEP=12
WPMGR_BACKUP_SCHEDULE_INTERVAL=5m
WPMGR_BACKUP_GC_INTERVAL=1h
WPMGR_BACKUP_HTTP_TIMEOUT=10m

# ---- Updates (M3) ----
# Per-tenant update parallelism; CP->agent command/probe timeout + retries.
# Format: integer / Go duration / integer. e.g. 5 / 30s / 2
WPMGR_UPDATE_PER_TENANT_PARALLELISM=5
WPMGR_UPDATE_HTTP_TIMEOUT=30s
WPMGR_UPDATE_HTTP_RETRIES=2

# ---- ClickHouse (metrics: M5 uptime time-series + analytics) ----
# Empty addr => metrics store disabled (uptime queries return empty; stack still
# runs). Format: WPMGR_CLICKHOUSE_ADDR host:port (NATIVE proto, port 9000);
# DB/USERNAME/PASSWORD strings. e.g. clickhouse:9000 / wpmgr_metrics / default
# NOTE: the app reads WPMGR_CLICKHOUSE_USERNAME; the compose server image is
# configured via CLICKHOUSE_USER (a different var) — keep them in sync.
WPMGR_CLICKHOUSE_ADDR=clickhouse:9000
WPMGR_CLICKHOUSE_DB=wpmgr_metrics
WPMGR_CLICKHOUSE_USERNAME=default
WPMGR_CLICKHOUSE_PASSWORD=

# ---- Uptime monitoring (M5) ----
# Probe interval/timeout/concurrency; alert interval; consecutive-down threshold.
# Format: durations / integers. e.g. 60s / 15s / 10 / 60s / 2
WPMGR_UPTIME_PROBE_INTERVAL=60s
WPMGR_UPTIME_PROBE_TIMEOUT=15s
WPMGR_UPTIME_PROBE_CONCURRENCY=10
WPMGR_UPTIME_ALERT_INTERVAL=60s
WPMGR_UPTIME_DOWN_THRESHOLD=2

# ---- Alert SMTP (M5 downtime alerts; M7 reports) ----
# The ops ALERT engine. Empty host => email alerts no-op (webhooks still fire).
# This is also the bootstrap fallback for transactional mail (the DB smtp_settings
# row, set in the dashboard, takes precedence). Any SMTP provider works.
# Format: HOST hostname; PORT integer; TLS_MODE starttls|tls|none; others strings.
WPMGR_SMTP_HOST=
WPMGR_SMTP_PORT=587
WPMGR_SMTP_USERNAME=
WPMGR_SMTP_PASSWORD=
WPMGR_SMTP_FROM=alerts@wpmgr.local
WPMGR_SMTP_TLS_MODE=starttls
# From/support address for transactional mail. Format: email. Default support@wpmgr.app.
WPMGR_SUPPORT_EMAIL=

# ---- One-Click Login (Phase 5.5) ----
# Feature flag for 2FA step-up on per-site autologin policies (no-op until TOTP
# ships). Format: true|false.
WPMGR_AUTOLOGIN_REQUIRE_2FA_STEP_UP=false

# ---- Media Optimizer (ADR-043, opt-in `media` profile) ----
# URL of the media-encoder service for the scale-to-zero waker; empty disables the
# wake POST. Format: URL. e.g. http://media-encoder:8080
WPMGR_MEDIA_ENCODER_URL=
# Bounded encode concurrency — read ONLY by the media-encoder binary, not the api.
# Format: integer. e.g. 2
WPMGR_MEDIA_ENCODE_WORKERS=2

# ---- Telemetry ----
# Empty => OTLP export disabled (traces stay in-process). Format: collector URL.
# e.g. http://otel-lgtm:4318
WPMGR_OTEL_EXPORTER_OTLP_ENDPOINT=
# OTel service name. Format: string. e.g. wpmgr-api
WPMGR_OTEL_SERVICE_NAME=wpmgr-api

# ---- One-shot operations (run once, then UNSET) ----
# Each is read at boot, performs its action, and should be removed afterwards.
# WPMGR_SUPERADMIN_EMAILS        — comma-separated emails; grants is_superadmin
#                                  (seeds a new account + set-password link if absent).
# WPMGR_SUPERADMIN_RESET_EMAILS  — comma-separated emails; mints a reset link each.
# WPMGR_RECOVER_ACCOUNTS         — "email:org[,email2:org2]"; create user + reset link.
# WPMGR_GRANT_MEMBERSHIPS        — "email:org[,...]"; reconcile membership (no create).
# WPMGR_REVOKE_MEMBERSHIPS       — "email:org[,...]"; revoke membership.
WPMGR_SUPERADMIN_EMAILS=
WPMGR_SUPERADMIN_RESET_EMAILS=
WPMGR_RECOVER_ACCOUNTS=
WPMGR_GRANT_MEMBERSHIPS=
WPMGR_REVOKE_MEMBERSHIPS=


# =============================================================================
# [DOCKER-COMPOSE ONLY]  Read by the compose files / postgres init script — the
# Go app NEVER reads these. They provision the Postgres OWNER + app login roles.
# =============================================================================

# Privileged OWNER role the postgres image creates (POSTGRES_USER/PASSWORD).
# The compose migration DSN is built from these; the owner password MUST equal
# POSTGRES_PASSWORD. Format: role name / string.
WPMGR_DB_OWNER_USER=wpmgr
WPMGR_DB_OWNER_PASSWORD=wpmgr
# Password the postgres init script sets on the wpmgr_app LOGIN role. Keep equal
# to WPMGR_DB_PASSWORD above. Format: string.
WPMGR_DB_APP_PASSWORD=wpmgr-app-dev-secret


# =============================================================================
# [FRONTEND]  Baked into the web SPA at build time (Vite).
# =============================================================================
# API base URL the dashboard calls. Format: URL. e.g. http://localhost:8080
VITE_API_BASE_URL=http://localhost:8080
