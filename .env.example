# ---- Server ----
WPMGR_ENV=development
WPMGR_HTTP_ADDR=:8080
WPMGR_LOG_LEVEL=info

# ---- Postgres ----
# The APP connects as an unprivileged NOSUPERUSER NOBYPASSRLS role (RLS is real).
WPMGR_DB_HOST=localhost
WPMGR_DB_PORT=5432
WPMGR_DB_USER=wpmgr_app
WPMGR_DB_PASSWORD=wpmgr-app-dev-secret
WPMGR_DB_NAME=wpmgr
WPMGR_DB_SSLMODE=disable
# Owner/superuser DSN used ONLY to run migrations (creates/grants the wpmgr_app
# role + privileged DDL). Leave blank to reuse the app DSN (single-node dev). e.g.
#   postgres://wpmgr:wpmgr@localhost:5432/wpmgr?sslmode=disable
WPMGR_DB_MIGRATION_DSN=
# Dev escape hatch: allow the app to boot even if its DB role can bypass RLS.
# MUST be false in production (RLS is the tenant-isolation backstop).
WPMGR_ALLOW_RLS_BYPASS_ROLE=false
# --- docker-compose only ---
# OWNER role (compose creates Postgres with these; the app never uses them).
WPMGR_DB_OWNER_USER=wpmgr
WPMGR_DB_OWNER_PASSWORD=wpmgr
# App login role password (compose's postgres init creates wpmgr_app with this).
WPMGR_DB_APP_PASSWORD=wpmgr-app-dev-secret

# ---- Redis ----
WPMGR_REDIS_ADDR=localhost:6379
WPMGR_REDIS_PASSWORD=

# ---- S3-compatible object storage (self-host: SeaweedFS; managed: AWS S3) ----
WPMGR_S3_ENDPOINT=http://localhost:8333
WPMGR_S3_REGION=us-east-1
WPMGR_S3_BUCKET=wpmgr-backups
WPMGR_S3_ACCESS_KEY=wpmgr
WPMGR_S3_SECRET_KEY=wpmgr-dev-secret
WPMGR_S3_FORCE_PATH_STYLE=true

# ---- ClickHouse (metrics, M5 uptime + future analytics) ----
# Empty addr -> metrics disabled (probe writes no-op; uptime queries return empty).
WPMGR_CLICKHOUSE_ADDR=clickhouse:9000
WPMGR_CLICKHOUSE_DB=wpmgr_metrics
WPMGR_CLICKHOUSE_USERNAME=default
WPMGR_CLICKHOUSE_PASSWORD=

# ---- Alert SMTP (M5 downtime alerts; M7 reports) ----
# The ALERT engine only. Empty host -> email alerts no-op (webhooks still fire).
# TLS mode: starttls|tls|none. This is intentionally SEPARATE from the
# notification engine below so you can route ops alerts and user-facing
# transactional mail through different relays/senders.
WPMGR_SMTP_HOST=
WPMGR_SMTP_PORT=587
WPMGR_SMTP_USERNAME=
WPMGR_SMTP_PASSWORD=
WPMGR_SMTP_FROM=alerts@wpmgr.local
WPMGR_SMTP_TLS_MODE=starttls

# ---- Notification SMTP (M5.7 transactional: org/site-share invites, account) ----
# The NOTIFICATION engine — separate from the alert SMTP above. Powers user-facing
# transactional email (organisation + per-site-share invitations, account emails).
# Empty host -> notifications no-op and the API returns the accept link in the
# response so self-hosters without email can still invite (copy/paste the link).
# Any SMTP provider works (SendGrid, Mailgun, Brevo, Amazon SES, Postmark, Resend,
# or your own relay); GCP has no native SMTP. TLS mode: starttls|tls|none.
WPMGR_NOTIFY_SMTP_HOST=
WPMGR_NOTIFY_SMTP_PORT=587
WPMGR_NOTIFY_SMTP_USERNAME=
WPMGR_NOTIFY_SMTP_PASSWORD=
WPMGR_NOTIFY_SMTP_FROM=no-reply@example.com
WPMGR_NOTIFY_SMTP_FROM_NAME=WPMgr
WPMGR_NOTIFY_SMTP_TLS_MODE=starttls
# Base URL used to build invite accept links (e.g. https://app.example.com).
# Reuses WPMGR_PUBLIC_BASE_URL when set; override here only if different.
WPMGR_NOTIFY_PUBLIC_BASE_URL=

# ---- One-Click Login (Phase 5.5) ----
# Feature flag for the 2FA step-up requirement on per-site policies. Defaults
# false — when false, autologin_policies.require_2fa_step_up is ignored. The 2FA
# system itself (TOTP enroll/verify) is NOT built in V0; even with this true the
# 409 `2fa_required` path is unreachable until TOTP enrollment lands.
WPMGR_AUTOLOGIN_REQUIRE_2FA_STEP_UP=false

# ---- Uptime monitoring (M5) ----
WPMGR_UPTIME_PROBE_INTERVAL=60s
WPMGR_UPTIME_PROBE_TIMEOUT=15s
WPMGR_UPTIME_PROBE_CONCURRENCY=10
WPMGR_UPTIME_ALERT_INTERVAL=60s
# Downtime alert fires after this many CONSECUTIVE down probes (transition + dedupe).
WPMGR_UPTIME_DOWN_THRESHOLD=2

# ---- Auth ----
# Session secret: REQUIRED, >=32 bytes. The app refuses to boot on the
# placeholder or anything shorter. Generate one with: openssl rand -base64 48
WPMGR_SESSION_SECRET=
# Session lifetimes (Go duration). Optional; defaults shown.
WPMGR_AUTH_IDLE_TIMEOUT=168h
WPMGR_AUTH_ABSOLUTE_EXPIRY=720h
# OIDC relying party (self-host via Dex; leave issuer blank for email+password only).
WPMGR_OIDC_ISSUER=
WPMGR_OIDC_CLIENT_ID=
WPMGR_OIDC_CLIENT_SECRET=
WPMGR_OIDC_REDIRECT_URL=http://localhost:8080/auth/oidc/callback

# ---- Agent protocol ----
# Control-plane Ed25519 signing keypair (base64-std of raw keys: priv 64B, pub 32B).
# Signs CP->agent commands; the public half is returned to agents at enrollment so
# they can verify commands. Generate a fresh pair for production — these are DEV ONLY:
#   go run ./... (crypto/ed25519) or: openssl genpkey -algorithm ed25519 ...
WPMGR_AGENT_SIGNING_PRIVATE_KEY=aWuH1W3DSfBwuE/V/H9BEmV9IAJfK5d6F2RDfYSj/raBW+b26qHT3spd1gHSw7aXEXxZkg9E9WMspibSjSFsnQ==
WPMGR_AGENT_SIGNING_PUBLIC_KEY=gVvm9uqh097KXdYB0sO2lxF8WZIPRPVjLKYm0o0hbJ0=
# Agent request signature clock skew, heartbeat-staleness threshold, and the
# periodic health-check interval (Go durations). Defaults shown.
WPMGR_AGENT_SIGNATURE_SKEW=5m
WPMGR_AGENT_STALE_AFTER=10m
WPMGR_AGENT_HEALTH_INTERVAL=5m

# ---- Backups (M4) ----
# Public base URL of THIS control plane, reachable by agents — used to build the
# presign/manifest callback URLs sent to the agent. In real deploys set this to
# your public CP URL (e.g. https://wpmgr.example.com).
WPMGR_PUBLIC_BASE_URL=http://localhost:8080
# Presigned S3 URL TTL; retention window + monthly-archive keep; scheduler + GC cadence.
WPMGR_BACKUP_PRESIGN_TTL=1h
WPMGR_BACKUP_RETENTION_DAYS=30
WPMGR_BACKUP_MONTHLY_ARCHIVE_KEEP=12
WPMGR_BACKUP_SCHEDULE_INTERVAL=5m
WPMGR_BACKUP_GC_INTERVAL=1h
# Per-attempt HTTP timeout for CP->agent backup/restore commands. Must be long
# enough for the agent to dump+chunk+encrypt+upload a real-site snapshot inline
# (the CP holds the connection open). Distinct from WPMGR_UPDATE_HTTP_TIMEOUT
# (which stays snappy for the short update/probe path).
WPMGR_BACKUP_HTTP_TIMEOUT=10m

# ---- Updates (M3) ----
# Max concurrent update tasks per tenant (one tenant can't starve others).
WPMGR_UPDATE_PER_TENANT_PARALLELISM=5
# Timeout + retries for CP->agent command/probe calls (SSRF-hardened client).
WPMGR_UPDATE_HTTP_TIMEOUT=30s
WPMGR_UPDATE_HTTP_RETRIES=2

# ---- Telemetry ----
# Leave empty to disable OTLP export (traces still recorded in-process). Set to
# your collector, e.g. http://otel-lgtm:4318 when running the observability profile.
WPMGR_OTEL_EXPORTER_OTLP_ENDPOINT=
WPMGR_OTEL_SERVICE_NAME=wpmgr-api

# ---- Frontend (Vite) ----
VITE_API_BASE_URL=http://localhost:8080
