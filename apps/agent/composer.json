{
  "name": "wpmgr/agent",
  "description": "WPMgr WordPress agent plugin",
  "type": "wordpress-plugin",
  "license": "MIT",
  "require": {
    "php": ">=8.1",
    "ext-mysqli": "*",
    "ext-openssl": "*",
    "ext-sodium": "*",
    "ext-zip": "*",
    "ext-zlib": "*",
    "bjeavons/zxcvbn-php": "^1.4",
    "matthiasmullie/minify": "^1.3"
  },
  "require-dev": {
    "antecedent/patchwork": "^2.2",
    "brain/monkey": "^2.7",
    "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
    "php-stubs/wordpress-stubs": "^6.5",
    "phpcsstandards/phpcsextra": "^1.2",
    "phpstan/phpstan": "^2.0",
    "phpunit/phpunit": "^10.5",
    "squizlabs/php_codesniffer": "^3.9",
    "szepeviktor/phpstan-wordpress": "^2.0",
    "wp-coding-standards/wpcs": "^3.1",
    "yoast/phpunit-polyfills": "^2.0"
  },
  "autoload": {
    "classmap": [
      "includes/"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "WPMgr\\Agent\\Tests\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "antecedent/patchwork": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse --memory-limit=2G",
    "lint": "phpcs",
    "format": "phpcbf --report-summary --report-source || true"
  }
}
