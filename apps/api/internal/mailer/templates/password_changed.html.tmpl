{{template "header" .}}
          <h1 class="ink" style="margin:0 0 14px 0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:24px;line-height:1.3;font-weight:700;color:#16302E;">Your password was changed</h1>
          <p class="body" style="margin:0 0 16px 0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:16px;line-height:1.6;color:#3A4A48;">Hi {{.Name}}, the password for your {{.ProductName}} account was just changed. Here are the details:</p>

          <!-- DETAILS TABLE -->
          <table role="presentation" class="band" width="100%" cellpadding="0" cellspacing="0" border="0" style="background:#E6F4F3;border:1px solid #D8E2E1;border-radius:10px;margin:6px 0 8px 0;">
            <tr>
              <td class="k" style="padding:14px 16px;border-bottom:1px solid #D8E2E1;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:13px;color:#6B7280;width:130px;">When</td>
              <td style="padding:14px 16px;border-bottom:1px solid #D8E2E1;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:14px;color:#16302E;font-weight:600;">{{.When}}</td>
            </tr>
            <tr>
              <td class="k" style="padding:14px 16px;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:13px;color:#6B7280;">From IP</td>
              <td style="padding:14px 16px;font-family:'SFMono-Regular',Consolas,Menlo,Monaco,'Courier New',monospace;font-size:14px;color:#16302E;font-weight:600;">{{.IP}}</td>
            </tr>
          </table>

          <p class="body" style="margin:22px 0 8px 0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;font-size:14px;line-height:1.6;color:#3A4A48;"><strong style="color:#16302E;">Wasn't you?</strong> Your account may be at risk. Contact <a href="mailto:{{.SupportEmail}}" style="color:#0A6675;text-decoration:underline;font-weight:600;">{{.SupportEmail}}</a> immediately to secure it.</p>
{{template "footer" .}}
