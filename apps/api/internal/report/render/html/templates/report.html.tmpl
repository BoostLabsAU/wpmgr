<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{.ClientName}} — {{.PeriodLabel}}</title>
<style>
/* Base styles — inline, self-contained, no external assets */
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif; font-size: 15px; line-height: 1.6; color: #1a1a2e; background: #f8f9fa; }
.container { max-width: 860px; margin: 0 auto; padding: 32px 16px; }
/* Header */
.report-header { background: #fff; border-radius: 12px; padding: 32px; margin-bottom: 24px; border-left: 6px solid {{or .AccentColor "#3b82f6"}}; box-shadow: 0 1px 4px rgba(0,0,0,.07); }
.report-header .logo img { max-height: 56px; max-width: 200px; }
.report-header h1 { font-size: 26px; font-weight: 700; margin-top: 16px; color: #0f172a; }
.report-header .meta { color: #64748b; font-size: 13px; margin-top: 4px; }
.intro-text { margin-top: 16px; color: #374151; white-space: pre-wrap; }
/* Overview totals */
.totals-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(130px, 1fr)); gap: 12px; margin-bottom: 24px; }
.total-card { background: #fff; border-radius: 8px; padding: 16px; text-align: center; box-shadow: 0 1px 3px rgba(0,0,0,.06); }
.total-card .value { font-size: 28px; font-weight: 700; color: {{or .AccentColor "#3b82f6"}}; }
.total-card .label { font-size: 12px; color: #6b7280; margin-top: 4px; }
/* Section header */
.section-header { font-size: 18px; font-weight: 700; color: #0f172a; padding: 12px 0 8px; border-bottom: 2px solid {{or .AccentColor "#3b82f6"}}; margin: 28px 0 16px; }
/* Site cards */
.site-card { background: #fff; border-radius: 10px; padding: 20px 24px; margin-bottom: 16px; box-shadow: 0 1px 3px rgba(0,0,0,.06); page-break-inside: avoid; }
.site-card h3 { font-size: 16px; font-weight: 600; color: #0f172a; }
.site-card .url { font-size: 13px; color: #6b7280; }
.metrics-row { display: flex; flex-wrap: wrap; gap: 20px; margin-top: 12px; }
.metric-item { flex: 1; min-width: 120px; }
.metric-item .m-val { font-size: 20px; font-weight: 700; }
.metric-item .m-lbl { font-size: 12px; color: #6b7280; }
/* CWV ratings */
.rating-good { color: #16a34a; }
.rating-needs { color: #ca8a04; }
.rating-poor  { color: #dc2626; }
/* Uptime sparkline */
.sparkline { display: flex; align-items: flex-end; gap: 2px; height: 32px; margin-top: 10px; }
.spark-bar { flex: 1; border-radius: 2px; min-height: 4px; }
/* Powered-by footer */
.powered-by { text-align: center; font-size: 12px; color: #9ca3af; margin-top: 32px; padding-top: 16px; border-top: 1px solid #e5e7eb; }
/* Print */
@media print {
  body { background: #fff; }
  .container { max-width: 100%; padding: 0; }
  .site-card { box-shadow: none; border: 1px solid #e5e7eb; }
  .report-header { box-shadow: none; }
  @page { margin: 20mm; }
}
</style>
</head>
<body>
<div class="container">

<!-- Header -->
<div class="report-header">
  {{if .LogoURL}}<div class="logo"><img src="{{.LogoURL}}" alt="Logo"></div>{{end}}
  <h1>{{.ClientName}}{{if .Company}} — {{.Company}}{{end}}</h1>
  <div class="meta">Report for {{.PeriodLabel}} · Prepared by {{.AgencyName}}</div>
  {{if .IntroText}}<div class="intro-text">{{.IntroText}}</div>{{end}}
</div>

<!-- Overview totals -->
{{if .Sections.Overview}}
<div class="section-header">Overview</div>
<div class="totals-grid">
  <div class="total-card"><div class="value">{{.Totals.SiteCount}}</div><div class="label">Sites</div></div>
  <div class="total-card"><div class="value">{{printf "%.1f" .Totals.AvgUptimePct}}%</div><div class="label">Avg Uptime</div></div>
  <div class="total-card"><div class="value">{{.Totals.Incidents}}</div><div class="label">Incidents</div></div>
  <div class="total-card"><div class="value">{{.Totals.BackupsCount}}</div><div class="label">Backups</div></div>
  <div class="total-card"><div class="value">{{.Totals.UpdatesApplied}}</div><div class="label">Updates</div></div>
  {{if .Sections.Email}}<div class="total-card"><div class="value">{{.Totals.EmailsSent}}</div><div class="label">Emails Sent</div></div>{{end}}
</div>
{{end}}

<!-- Per-site details -->
{{range .Sites}}
<div class="section-header">{{.Name}}</div>
<div class="site-card">
  <h3>{{.Name}}</h3>
  <div class="url">{{.URL}}</div>

  {{if .Uptime}}
  <div class="metrics-row" style="margin-top:12px;">
    <div class="metric-item"><div class="m-val">{{printf "%.2f" .Uptime.UptimePct}}%</div><div class="m-lbl">Uptime</div></div>
    <div class="metric-item"><div class="m-val">{{printf "%.0f" .Uptime.AvgLatencyMs}}ms</div><div class="m-lbl">Avg Latency</div></div>
    <div class="metric-item"><div class="m-val">{{.Uptime.Incidents}}</div><div class="m-lbl">Incidents</div></div>
    {{if .Uptime.TLSExpiry}}<div class="metric-item"><div class="m-val">{{.Uptime.TLSExpiry.Format "2 Jan 2006"}}</div><div class="m-lbl">TLS Expiry</div></div>{{end}}
  </div>
  {{if .Uptime.Daily}}
  <div class="sparkline" title="Daily uptime">
    {{range .Uptime.Daily}}<div class="spark-bar" style="background:{{uptimeColor .UptimePct}};height:{{sparkHeight .UptimePct}}px;" title="{{printf "%.1f" .UptimePct}}%"></div>{{end}}
  </div>
  {{end}}
  {{end}}

  {{if .Backups}}
  <div class="metrics-row">
    <div class="metric-item"><div class="m-val">{{.Backups.CompletedInPeriod}}</div><div class="m-lbl">Backups</div></div>
    <div class="metric-item"><div class="m-val">{{bytesHuman .Backups.TotalBytes}}</div><div class="m-lbl">Total Size</div></div>
    {{if .Backups.LastCompletedAt}}<div class="metric-item"><div class="m-val">{{.Backups.LastCompletedAt.Format "2 Jan"}}</div><div class="m-lbl">Last Backup</div></div>{{end}}
  </div>
  {{end}}

  {{if .Updates}}
  <div class="metrics-row">
    <div class="metric-item"><div class="m-val">{{.Updates.Total}}</div><div class="m-lbl">Updates Applied</div></div>
    <div class="metric-item"><div class="m-val">{{.Updates.Plugins}}</div><div class="m-lbl">Plugins</div></div>
    <div class="metric-item"><div class="m-val">{{.Updates.Themes}}</div><div class="m-lbl">Themes</div></div>
    {{if .Updates.Failed}}<div class="metric-item"><div class="m-val rating-poor">{{.Updates.Failed}}</div><div class="m-lbl">Failed</div></div>{{end}}
  </div>
  {{end}}

  {{if .Performance}}
  {{if .Performance.Metrics}}
  <div class="metrics-row">
    {{range .Performance.Metrics}}
    <div class="metric-item">
      <div class="m-val {{ratingClass .Rating}}">{{cwvDisplay .Metric .P75}}</div>
      <div class="m-lbl">{{upper .Metric}} p75</div>
    </div>
    {{end}}
  </div>
  {{end}}
  {{end}}

  {{if .Email}}
  <div class="metrics-row">
    <div class="metric-item"><div class="m-val">{{.Email.Sent}}</div><div class="m-lbl">Emails Sent</div></div>
    {{if .Email.Failed}}<div class="metric-item"><div class="m-val rating-poor">{{.Email.Failed}}</div><div class="m-lbl">Failed</div></div>{{end}}
    {{if .Email.Bounced}}<div class="metric-item"><div class="m-val rating-needs">{{.Email.Bounced}}</div><div class="m-lbl">Bounced</div></div>{{end}}
  </div>
  {{end}}

</div>
{{end}}

{{if .ClosingText}}<div style="background:#fff;border-radius:8px;padding:20px 24px;margin-top:16px;color:#374151;white-space:pre-wrap;">{{.ClosingText}}</div>{{end}}

{{if .ShowPoweredBy}}
<div class="powered-by">Prepared with WPMgr</div>
{{end}}

</div>
</body>
</html>
