# syntax=docker/dockerfile:1

# ---- build stage ----
# Build the @wpmgr/web Vite React SPA with Node 22 + pnpm.
# Build context is the repo root (pnpm workspace).
FROM node:22-alpine AS build

# Enable the pinned pnpm via corepack.
RUN corepack enable

WORKDIR /repo

# Copy workspace manifests first for better layer caching.
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY apps/web/package.json ./apps/web/
COPY packages ./packages

# Fetch the lockfile-resolved store, then install. Use a fetch+offline install
# so the dependency download layer is cached independent of source changes.
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile --filter @wpmgr/web...

# Copy the web app source and build. BUILD_VERSION is injected by vite at
# build time via __BUILD_VERSION__ define (see apps/web/vite.config.ts).
# The deploy pipeline passes the release tag via --build-arg BUILD_VERSION=...
# so the dashboard's footer + SSE handshake report the actual shipped version.
ARG BUILD_VERSION=local
ENV BUILD_VERSION=${BUILD_VERSION}
COPY apps/web ./apps/web
RUN pnpm --filter @wpmgr/web build

# ---- final stage ----
FROM nginx:1.27-alpine

# SPA + /api proxy config.
COPY infra/nginx/nginx.conf /etc/nginx/conf.d/default.conf

# Static build output.
COPY --from=build /repo/apps/web/dist /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD wget -qO- http://localhost/ >/dev/null 2>&1 || exit 1
