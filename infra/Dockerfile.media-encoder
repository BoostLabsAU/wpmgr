# syntax=docker/dockerfile:1

# ---- build stage ----
# Multi-stage build of the WPMgr Media Optimizer encode worker (cmd/media-encoder,
# ADR-043). Unlike the main API (infra/Dockerfile.api, CGO_ENABLED=0 on
# distroless/static), this binary links the CGO lilliput encoder + its bundled
# native codec libs (libaom/dav1d/etc.), so it builds with CGO_ENABLED=1 against
# a glibc base. The main API NEVER imports the encoder — these are two distinct
# images by design.
FROM golang:1.26 AS build

# CGO ON. linux/amd64 (lilliput ships prebuilt static codec libs for it).
ENV CGO_ENABLED=1 \
    GOWORK=off \
    GOOS=linux \
    GOARCH=amd64

WORKDIR /src

# Cache module downloads. The api module's go.mod/go.sum are the only ones
# needed when GOWORK=off.
COPY apps/api/go.mod apps/api/go.su[m] ./apps/api/
RUN --mount=type=cache,target=/go/pkg/mod \
    cd apps/api && go mod download || true

# lilliput is the CGO image library (ADR-043 §1, MIT). Pin v1.5.0. (Already in
# go.mod; this `go get` is belt-and-braces so the build is reproducible even if
# the module graph is regenerated.)
RUN --mount=type=cache,target=/go/pkg/mod \
    cd apps/api && go get github.com/discord/lilliput@v1.5.0

# Copy the api module source.
COPY apps/api ./apps/api

ARG VERSION=0.0.0-dev

# Build the CGO binary. No -s -w stripping issues: keep it simple + reproducible.
#
# lilliput's CFLAGS add -I.../deps/linux/amd64/include and opencv.cpp does
# `#include <png.h>`, but in lilliput's repo the linux root-level png.h /
# pngconf.h / pnglibconf.h are SYMLINKS into libpng16/. Go's module zip format
# strips symlinks, so the read-only module cache is missing those three headers
# (osx ships them as real files, which is why a local darwin build succeeds).
# Add the libpng16/ subdir to the cgo include path so <png.h> resolves to the
# bundled header. The failing translation unit is lilliput's opencv.cpp — a C++
# file — so the include dir MUST be on CGO_CXXFLAGS (the C++ flag); CGO_CFLAGS
# alone is ignored by the C++ compile. We set both for belt-and-braces. Linking
# still uses lilliput's bundled static libpng16.a (LDFLAGS), so the distroless/cc
# runtime needs no system libpng.
RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    cd apps/api && \
    LILLI_INC="$(go env GOMODCACHE)/github.com/discord/lilliput@v1.5.0/deps/linux/amd64/include" && \
    export CGO_CFLAGS="-I${LILLI_INC}/libpng16" CGO_CXXFLAGS="-I${LILLI_INC}/libpng16" && \
    go build -trimpath \
        -ldflags "-X main.version=${VERSION}" \
        -o /out/media-encoder ./cmd/media-encoder

# ---- final stage ----
# debian:trixie-slim — we need a package manager in the runtime layer because
# headless Chromium (go-rod screenshot worker) has ~168 transitive shared-lib
# deps that make copying individual .so files into a distroless image
# impractical.
#
# WHY NOT distroless/cc-debian13 any more: distroless has no shell and no apt.
# Chromium's wrapper at /usr/bin/chromium IS a shell script that execs
# /usr/lib/chromium/chromium — so we need /bin/sh in the final image.
# debian:trixie-slim ships glibc 2.41 + libstdc++ from GCC 14 (identical ABI
# to distroless/cc-debian13), so the lilliput CGO requirement is still met.
#
# CRITICAL: stay on Debian 13 "trixie" to match golang:1.26 (also trixie).
# The binary requires GLIBC_2.38+ and GLIBCXX_3.4.32+; a debian12 runtime
# dies at startup before it can bind $PORT.
#
# BINARY PATH MISMATCH: the Go code hard-codes /usr/bin/chromium-browser
# (capture/worker.go const chromiumBin). On Debian trixie the `chromium`
# package installs at /usr/bin/chromium (no -browser suffix). We add a symlink
# /usr/bin/chromium-browser -> /usr/bin/chromium so exec.LookPath finds it.
#
# NON-ROOT: uid/gid 65532 ("nonroot") is created manually to mirror the uid
# the distroless image used. Chromium runs with --no-sandbox (set by the Go
# launcher) which is required in any container environment regardless of user.
FROM debian:trixie-slim

# Install Chromium + runtime libraries it needs for headless operation.
# One RUN layer: install → symlink → clean → adduser. Cache is purged in the
# same layer to keep the image lean (apt lists alone are ~50 MB).
#
# Package notes:
#   chromium              — browser + its auto-pulled libs (~168 packages)
#   fonts-liberation      — metrically-compatible Arial/Times/Courier (pulled
#                           automatically by chromium on trixie; listed
#                           explicitly for clarity)
#   fonts-noto-color-emoji — emoji fallback; prevents □ boxes in screenshots
#   fonts-noto-cjk        — CJK (Chinese/Japanese/Korean) fallback; prevents
#                           tofu on Asian-language sites
#   ca-certificates       — TLS roots for the SSRF-proxy CONNECT tunnel
#
# dbus, libnss3, libnspr4, libatk*, libgbm1, libasound2t64, libpango*,
# libcairo2, libgtk-3* are all pulled as chromium dependencies automatically.
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        chromium \
        fonts-noto-color-emoji \
        fonts-noto-cjk \
        ca-certificates \
    && ln -s /usr/bin/chromium /usr/bin/chromium-browser \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --gid 65532 nonroot \
    && useradd --uid 65532 --gid 65532 --no-create-home --shell /usr/sbin/nologin nonroot

WORKDIR /
COPY --from=build /out/media-encoder /usr/local/bin/media-encoder

USER nonroot:nonroot

ENTRYPOINT ["/usr/local/bin/media-encoder"]
