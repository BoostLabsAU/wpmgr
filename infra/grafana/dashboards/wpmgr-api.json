{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "WPMgr API — Overview",
  "tags": ["wpmgr"],
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "HTTP requests / sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_server_requests_total{service=\"wpmgr-api\"}[5m]))"
        }
      ]
    },
    {
      "id": 2,
      "title": "Process resident memory (bytes)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "process_resident_memory_bytes{service=\"wpmgr-api\"}"
        }
      ]
    }
  ]
}
